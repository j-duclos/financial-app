# Backend
# Use SQLite (backend/db.sqlite3) when DATABASE_URL is unset. Uncomment below for Postgres.
# DATABASE_URL=postgres://user:password@localhost:5432/budget
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PAGE_SIZE=20

# Plaid — https://dashboard.plaid.com/team/keys
# PLAID_SANDBOX_* vs PLAID_PRODUCTION_* so sandbox host never accidentally gets the prod secret.
PLAID_CLIENT_ID=69f11e323f84fb000dbc96a6
# production → api hosts production.plaid.com + PLAID_PRODUCTION_SECRET (real institutions).
PLAID_ENV=production
PLAID_SANDBOX_SECRET=d93091efc8974e0cabb7f59575b5c2
PLAID_PRODUCTION_SECRET=a74362029e634731861a43d29327fd
# PLAID_REDIRECT_URI=https://9f703f2ff273da.lhr.life/transactions
# Optional Fernet key for encrypting stored access tokens (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# PLAID_TOKEN_FERNET_KEY=

# Web (Vite)
VITE_API_URL=http://localhost:8000

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:8000
