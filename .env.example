# Backend — copy to budget-app/backend/.env for local dev (not committed).
#
# Local Postgres (Docker Compose maps 5433→5432). Comment out to use SQLite (backend/db.sqlite3).
DATABASE_URL=postgres://budget:budget@localhost:5433/budget
#
# Render production: do NOT paste localhost here — link Postgres in the Render Dashboard;
# Render sets DATABASE_URL automatically to something like postgres://user:pass@dpg-xxx/budget
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production (Render): comma-separated https origins (no trailing slash)
# ALLOWED_HOSTS=budget-app-api.onrender.com,.onrender.com
# CSRF_TRUSTED_ORIGINS=https://budget-app-api.onrender.com,https://budget-app-web.onrender.com
# CORS_ALLOWED_ORIGINS=https://budget-app-web.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PAGE_SIZE=20

# Plaid — keys from https://dashboard.plaid.com/team/keys
# Load these into budget-app/backend/.env (used when you run Django locally).
# Same variables work in Docker if you pass them (see docker-compose.yml / root .env).
#
# PLAID_CLIENT_ID is one ID for all environments (shown once on the Keys page).
#
# IMPORTANT — two different ideas people mix up:
# (1) Dashboard "Sandbox" vs "Production" SECRET are different passwords Plaid gives you.
# (2) PLAID_ENV tells THIS APP which Plaid API server to call (sandbox.plaid.com vs production.plaid.com).
#     While PLAID_ENV=sandbox, your requests NEVER touch live banks — even if you pasted the Production
#     secret (that usually yields INVALID_API_KEYS because secret must match the server).
# To link REAL institutions: set PLAID_ENV=production, put the Production secret in PLAID_SECRET or
# PLAID_PRODUCTION_SECRET, restart Django — and your Plaid account must have Production access enabled.
#
# Secrets must match PLAID_ENV / API host. Optional explicit vars avoid swapping PLAID_SECRET:
# PLAID_SANDBOX_SECRET, PLAID_DEVELOPMENT_SECRET, PLAID_PRODUCTION_SECRET (each falls back to PLAID_SECRET).
# If Plaid returns INVALID_API_KEYS, client_id + secret don't match that environment's Keys row.
PLAID_CLIENT_ID=
PLAID_SECRET=
# PLAID_SANDBOX_SECRET=
# PLAID_PRODUCTION_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox
# Optional: Fernet key from `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
# If unset, tokens are encrypted using a key derived from DJANGO_SECRET_KEY (rotate secret = lose tokens).
PLAID_TOKEN_FERNET_KEY=
# Optional: E.164 phone passed into Link token user (+14155552671). Omit dashes/spaces.
# PLAID_LINK_USER_PHONE=
#
# OAuth redirect (optional server default when the browser does not send redirect_uri):
# https://<frontend-host>/plaid/oauth-return — must match Plaid Dashboard → Allowed redirect URIs.
# The web app normally sends VITE_PLAID_REDIRECT_URI or origin + /plaid/oauth-return from the client.
# PLAID_REDIRECT_URI=https://budget-app-web.onrender.com/plaid/oauth-return

# Web (Vite) — see apps/web/.env.example
# Local: omit VITE_API_URL (same-origin /api via Vite proxy).
# Render Static Site: VITE_API_URL=https://budget-app-api.onrender.com
# Plaid: VITE_PLAID_REDIRECT_URI=https://budget-app-web.onrender.com/plaid/oauth-return

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:8000
