# Copy values from your local files into Render Dashboard → Environment → Bulk import.
# Sources: backend/.env, backend/.env.render, and any secrets you saved separately.
#
# Do NOT commit this file with real values. Use as a checklist only.

# Required
DJANGO_SECRET_KEY=
DEBUG=false
# Dashboard/timeline [PERF] logs in Render → Logs (no need for DEBUG=true)
ENABLE_PERF_LOGS=true
NODE_VERSION=20

# Postgres — prefer linking the DB in Render (auto-sets DATABASE_URL). Or paste External URL:
DATABASE_URL=

# App hosts (replace with your *.onrender.com hostname)
ALLOWED_HOSTS=financial-app-5ywr.onrender.com,.onrender.com
CSRF_TRUSTED_ORIGINS=https://financial-app-5ywr.onrender.com
# CORS_ALLOWED_ORIGINS=   # optional when UI is served from same web service

# Gunicorn (paid tier)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=240

# Plaid — copy from backend/.env (values also in scripts/.render-env-export after export-render-env.sh)
#
# Real banks (Chase): production row from dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=
PLAID_ENV=production
PLAID_PRODUCTION_SECRET=
#
# Fake institutions only:
# PLAID_ENV=sandbox
# PLAID_SANDBOX_SECRET=
#
# Must match your Web Service hostname (also allowlist in Plaid Dashboard → Allowed redirect URIs)
PLAID_REDIRECT_URI=https://financial-app-5ywr.onrender.com/plaid/oauth-return
#
# Required if you imported data or linked banks before the env wipe — otherwise re-link banks on Render.
# Local: python manage.py plaid_fernet_key_for_render  (only if PLAID_TOKEN_FERNET_KEY was set locally)
PLAID_TOKEN_FERNET_KEY=

# Optional performance
# Render: New → Key Value (Starter) → copy Internal Redis URL (redis://…)
REDIS_URL=
