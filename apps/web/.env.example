# Copy to apps/web/.env.local for local overrides (not committed).

# Production (Render Static Site): backend Web Service URL, no trailing slash.
# VITE_API_URL=https://budget-app-api.onrender.com

# Optional alias for the same value:
# VITE_API_BASE_URL=https://budget-app-api.onrender.com

# Local dev: omit both — API requests use same-origin /api and Vite proxies to localhost:8000.

# Plaid OAuth redirect_uri sent when creating a link token (must match Plaid Dashboard allowlist).
# Default when unset: {current origin}/plaid/oauth-return
# VITE_PLAID_REDIRECT_URI=https://budget-app-web.onrender.com/plaid/oauth-return
